{
  "$schema": "http://json-schema.org/draft-07/schema",
  "title": "Execution Notifications",
  "description": "jupyterlab-notify settings.",
  "jupyter.lab.setting-icon": "notify:bell-outline",
  "jupyter.lab.toolbars": {
    "Notebook": [
      {
        "name": "notifyType",
        "rank": 80
      }
    ],
    "Cell": [
      {
        "name": "cellNotifyMenu",
        "rank": 100
      }
    ]
  },
  "properties": {
    "defaultMode": {
      "title": "Default mode",
      "description": "The default mode for notification",
      "type": "string",
      "enum": ["default", "never", "on-error", "custom-timeout"],
      "default": "default"
    },
    "defaultThreshold": {
      "title": "Threshold for default notification",
      "description": "Default threshold value (unit in seconds)",
      "type": ["number", "null"],
      "default": 30,
      "minimum": 0
    },
    "customTimeout": {
      "title": "Timeout value for timeout notifications",
      "description": "Default timeout value for custom-timeout notification (unit in seconds)",
      "type": ["number", "null"],
      "default": 30,
      "minimum": 0
    },
    "successMessage": {
      "title": "Success message",
      "description": "Default message shown on successful cell execution",
      "type": "string",
      "default": "Cell execution completed successfully"
    },
    "failureMessage": {
      "title": "Failure message",
      "description": "Default message shown on cell execution failure",
      "type": "string",
      "default": "Cell execution failed"
    },
    "mail": {
      "title": "Send email",
      "description": "Send email notification including the cell result",
      "type": "boolean",
      "default": false,
      "disabled": true
    },
    "slack": {
      "title": "Send slack notification",
      "description": "Send slack notification including the cell result",
      "type": "boolean",
      "default": false,
      "disabled": true
    }
  },
  "additionalProperties": false,
  "type": "object"
}
